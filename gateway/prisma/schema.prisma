// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id            String   @id @default(uuid())
  trace_id      String
  timestamp     DateTime @default(now())
  endpoint      String
  masked_prompt String   @db.Text
  items_masked  Int
  provider      String
  model         String
  latency_ms    Int
  status_code   Int
}

model ApiKey {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  owner_email String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
